<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.ArtworkController"
      spacing="0" styleClass="content-area">

    <!-- En-tête -->
    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Oeuvres" styleClass="page-title" />
            <Label text="Catalogue complet des oeuvres de la plateforme." styleClass="page-subtitle" />
        </VBox>
        <Label text="Filtrer par tag :" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
        <ComboBox fx:id="tagFilter" promptText="Tous les tags" prefWidth="180" />
    </HBox>

    <!-- Corps -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>

        <!-- Tableau -->
        <VBox spacing="10" HBox.hgrow="ALWAYS">
            <TableView fx:id="artworkTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="titleColumn"  text="Titre"   prefWidth="200" />
                    <TableColumn fx:id="artistColumn" text="Artiste" prefWidth="150" />
                    <TableColumn fx:id="typeColumn"   text="Type"    prefWidth="100" />
                    <TableColumn fx:id="priceColumn"  text="Prix"    prefWidth="90" />
                    <TableColumn fx:id="statusColumn" text="Statut"  prefWidth="120" />
                </columns>
                <placeholder><Label text="Aucune oeuvre trouvée." /></placeholder>
            </TableView>

            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Button fx:id="btnAvis"   text="★ Laisser un avis" onAction="#handleLaisserAvis"
                        style="-fx-background-color: #F5EFE6; -fx-text-fill: #6D2E46; -fx-font-weight: bold; -fx-border-color: #6D2E46; -fx-border-radius: 6; -fx-background-radius: 6;" />
                <Button fx:id="btnAdd"    text="+ Ajouter"  onAction="#handleAddArtwork"    styleClass="button-primary" />
                <Button fx:id="btnEdit"   text="Modifier"   onAction="#handleEditArtwork" />
                <Button fx:id="btnDelete" text="Supprimer"  onAction="#handleDeleteArtwork" />
            </HBox>
        </VBox>

        <!-- Détails -->
        <VBox spacing="12" prefWidth="340" minWidth="300" styleClass="details-pane">

            <Label text="Détails" style="-fx-font-family: Georgia; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" />
            <Separator />

            <VBox spacing="2">
                <Label text="OEUVRE" styleClass="detail-key" />
                <Label fx:id="detailsTitleLabel" text="—"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;"
                       wrapText="true" />
            </VBox>

            <VBox spacing="2">
                <Label text="ARTISTE" styleClass="detail-key" />
                <Label fx:id="detailsArtistLabel" text="—" styleClass="detail-label" />
            </VBox>

            <VBox spacing="2">
                <Label text="PRIX" styleClass="detail-key" />
                <Label fx:id="detailsPriceLabel" text="—"
                       style="-fx-font-weight: bold; -fx-text-fill: #2D6A4F; -fx-font-size: 14px;" wrapText="true" />
            </VBox>
            <VBox spacing="2">
                <Label text="NOTE MOYENNE" styleClass="detail-key" />
                <Label fx:id="detailsRatingLabel" text="—" styleClass="rating-label" wrapText="true" />
            </VBox>

            <VBox spacing="2">
                <Label text="METADATA" styleClass="detail-key" />
                <Label fx:id="detailsMetaLabel" text="—" styleClass="detail-label" wrapText="true" />
            </VBox>

            <VBox spacing="2">
                <Label text="TAGS" styleClass="detail-key" />
                <Label fx:id="detailsTagsLabel" text="—" styleClass="tags-label" wrapText="true" />
            </VBox>

            <VBox spacing="2" VBox.vgrow="ALWAYS">
                <Label text="DESCRIPTION" styleClass="detail-key" />
                <TextArea fx:id="detailsDescriptionArea" prefRowCount="3" wrapText="true"
                          style="-fx-background-color: #F8F6F3; -fx-border-color: transparent;" />
            </VBox>

            <VBox spacing="2">
                <Label text="AVIS" styleClass="detail-key" />
                <TextArea fx:id="detailsReviewsArea" prefRowCount="4" editable="false" wrapText="true"
                          style="-fx-background-color: #F8F6F3; -fx-border-color: transparent;" />
            </VBox>

        </VBox>
    </HBox>
</VBox>
