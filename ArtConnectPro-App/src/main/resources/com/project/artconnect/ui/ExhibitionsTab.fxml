<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.ExhibitionController"
      spacing="0" styleClass="content-area">

    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Expositions" styleClass="page-title" />
            <Label text="Toutes les expositions organisées sur la plateforme." styleClass="page-subtitle" />
        </VBox>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>

        <!-- Tableau -->
        <VBox spacing="10" HBox.hgrow="ALWAYS">
            <TableView fx:id="exhibitionTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="titleColumn"    text="Titre"     prefWidth="200" />
                    <TableColumn fx:id="galleryColumn"  text="Galerie"   prefWidth="150" />
                    <TableColumn fx:id="dateColumn"     text="Début"     prefWidth="110" />
                    <TableColumn fx:id="endDateColumn"  text="Fin"       prefWidth="110" />
                    <TableColumn fx:id="themeColumn"    text="Thème"     prefWidth="140" />
                    <TableColumn fx:id="curatorColumn"  text="Curateur"  prefWidth="130" />
                </columns>
                <placeholder><Label text="Aucune exposition trouvée." /></placeholder>
            </TableView>

            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Button fx:id="btnAdd"    text="+ Créer"    onAction="#handleAddExhibition"    styleClass="button-primary" />
                <Button fx:id="btnEdit"   text="Modifier"   onAction="#handleEditExhibition" />
                <Button fx:id="btnDelete" text="Supprimer"  onAction="#handleDeleteExhibition" />
            </HBox>
        </VBox>

        <!-- Détails -->
        <VBox spacing="12" prefWidth="340" minWidth="300" styleClass="details-pane">

            <Label text="Détails" style="-fx-font-family: Georgia; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" />
            <Separator />

            <VBox spacing="2">
                <Label text="EXPOSITION" styleClass="detail-key" />
                <Label fx:id="detailsTitleLabel" text="—"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;"
                       wrapText="true" />
            </VBox>

            <VBox spacing="2">
                <Label text="GALERIE" styleClass="detail-key" />
                <Label fx:id="detailsGalleryLabel" text="—" styleClass="detail-label" wrapText="true" />
            </VBox>

            <VBox spacing="2">
                <Label text="PLANNING" styleClass="detail-key" />
                <Label fx:id="detailsScheduleLabel" text="—" styleClass="detail-label" wrapText="true" />
            </VBox>

            <VBox spacing="2" VBox.vgrow="ALWAYS">
                <Label text="OEUVRES EXPOSEES" styleClass="detail-key" />
                <TextArea fx:id="detailsArtworksArea" prefRowCount="6" editable="false" wrapText="true"
                          style="-fx-background-color: #F8F6F3; -fx-border-color: transparent;" />
            </VBox>

        </VBox>
    </HBox>
</VBox>
