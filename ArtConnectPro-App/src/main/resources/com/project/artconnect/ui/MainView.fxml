<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.project.artconnect.ui.MainController"
            styleClass="main-window"
            stylesheets="@artconnect.css"
            prefWidth="1200" prefHeight="800">

    <!-- ============================================================ -->
    <!-- SIDEBAR                                                      -->
    <!-- ============================================================ -->
    <left>
        <VBox styleClass="sidebar" spacing="0" prefWidth="200">

            <!-- Logo -->
            <VBox styleClass="sidebar-header" spacing="4">
                <Label text="ArtConnect" styleClass="sidebar-logo" />
                <Label text="Plateforme artistique" styleClass="sidebar-tagline" />
            </VBox>

            <!-- Utilisateur connecté -->
            <VBox fx:id="userInfoBox" styleClass="sidebar-user" spacing="3">
                <Label fx:id="sidebarUserName" text="—" styleClass="sidebar-user-name" />
                <Label fx:id="sidebarUserRole" text="—" styleClass="sidebar-user-role" />
            </VBox>

            <Label text="NAVIGATION" styleClass="sidebar-section-label" />

            <Button fx:id="navDiscover"     text="  Discover"         onAction="#showDiscover"     styleClass="nav-button" maxWidth="Infinity" />
            <Button fx:id="navArtists"      text="  Artists"          onAction="#showArtists"      styleClass="nav-button" maxWidth="Infinity" />
            <Button fx:id="navArtworks"     text="  Artworks"         onAction="#showArtworks"     styleClass="nav-button" maxWidth="Infinity" />
            <Button fx:id="navGalleries"    text="  Galleries"        onAction="#showGalleries"    styleClass="nav-button" maxWidth="Infinity" />
            <Button fx:id="navExhibitions"  text="  Exhibitions"      onAction="#showExhibitions"  styleClass="nav-button" maxWidth="Infinity" />
            <Button fx:id="navWorkshops"    text="  Workshops"        onAction="#showWorkshops"    styleClass="nav-button" maxWidth="Infinity" />
            <Button fx:id="navCommunity"    text="  Community"        onAction="#showCommunity"    styleClass="nav-button" maxWidth="Infinity" />
            <Button fx:id="navInscriptions" text="  Mes Inscriptions" onAction="#showInscriptions" styleClass="nav-button" maxWidth="Infinity" />
            <Button fx:id="navAdmin"        text="  Admin"            onAction="#showAdmin"        styleClass="nav-button" maxWidth="Infinity" />

            <Region VBox.vgrow="ALWAYS" />
            <Separator />
            <Label fx:id="sidebarModeLabel" text="Mode : MySQL" styleClass="sidebar-section-label" />
            <Button text="  Se deconnecter" onAction="#handleLogout"
                    styleClass="nav-button, nav-button-logout" maxWidth="Infinity" />

        </VBox>
    </left>

    <!-- ============================================================ -->
    <!-- CONTENU — StackPane avec toutes les vues                     -->
    <!-- ============================================================ -->
    <center>
        <StackPane fx:id="contentStack" styleClass="content-area">
            <fx:include fx:id="discoverView"     source="DiscoverTab.fxml" />
            <fx:include fx:id="artistsView"      source="ArtistsTab.fxml" />
            <fx:include fx:id="artworksView"     source="ArtworksTab.fxml" />
            <fx:include fx:id="galleriesView"    source="GalleriesTab.fxml" />
            <fx:include fx:id="exhibitionsView"  source="ExhibitionsTab.fxml" />
            <fx:include fx:id="workshopsView"    source="WorkshopsTab.fxml" />
            <fx:include fx:id="communityView"    source="CommunityTab.fxml" />
            <fx:include fx:id="inscriptionsView" source="MesInscriptionsTab.fxml" />
            <fx:include fx:id="adminView"        source="AdminTab.fxml" />
        </StackPane>
    </center>

    <!-- ============================================================ -->
    <!-- BARRE DE STATUT                                              -->
    <!-- ============================================================ -->
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_RIGHT">
            <Label fx:id="modeLabel" text="ArtConnect Pro v1.0" styleClass="status-label" />
        </HBox>
    </bottom>

</BorderPane>
